# ── Animated spinner ──────────────────────────────────────────────────
_FRAMES = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
_COLS   = [O, G, YL, GR, CY, BL, PR, WH, O, G]

def _spinner(stop: threading.Event) -> None:
    i     = 0
    label = "Analyzing task complexity"
    while not stop.is_set():
        color = _COLS[i % len(_COLS)]
        frame = _FRAMES[i % len(_FRAMES)]
        dots  = "·" * ((i // 5) % 4) + " " * (3 - (i // 5) % 4)
        bar_n = (i // 3) % 13
        bar   = f"{GR}{'█' * bar_n}{GY}{'░' * (12 - bar_n)}{R}"
        sys.stdout.write(
            f"\r  {color}{BD}{frame}{R}  {WH}{label}{R}{GY}{dots}{R}  {bar}  "
        )
        sys.stdout.flush()
        i += 1
        time.sleep(0.07)
    sys.stdout.write("\r" + " " * 65 + "\r")
    sys.stdout.flush()

# ── Classifier ────────────────────────────────────────────────────────
def _classify_raw(prompt: str) -> str:
    client  = OpenAI(base_url=OR_BASE, api_key=OR_KEY)
    user_msg = (
        "Classify this AI task as easy or hard. "
        "easy=Q&A/simple-code/explain/debug/format/scripts. "
        "hard=complex-architecture/multi-system-design/advanced-research/novel-algorithms. "
        'Reply ONLY with JSON: {"d":"easy"} or {"d":"hard"}\n\nTask: ' + prompt[:800]
    )
    try:
        r = client.chat.completions.create(
            model=CLASSIFIER_MODEL,
            messages=[{"role": "user", "content": user_msg}],
            max_tokens=20,
            temperature=0,
        )
        raw = r.choices[0].message.content.strip().strip("`").strip()
        if raw.startswith("json"):
            raw = raw[4:].strip()
        return json.loads(raw).get("d", "easy")
    except Exception as e:
        sys.stderr.write(f"\n[classifier: {e}] defaulting to easy\n")
        return "easy"

def classify(prompt: str) -> str:
    stop = threading.Event()
    t    = threading.Thread(target=_spinner, args=(stop,), daemon=True)
    t.start()
    try:
        result = _classify_raw(prompt)
    finally:
        stop.set()
        t.join()
    return result

# ── Route label ───────────────────────────────────────────────────────
def print_route(difficulty: str, tag: str = "") -> None:
    if difficulty == "easy":
        print(
            f"\n  {BL}{BD}▸{R}  {CY}{BD}qwen/qwen3-coder{R}  "
            f"{GY}[easy]{R}  {GR}cheap ✓{R}  {GY}{tag}{R}\n"
        )
    else:
        print(
            f"\n  {O}{BD}▸{R}  {O}{BD}claude-opus-4.8{R}   "
            f"{YL}[hard]{R}  {O}powerful ✓{R}  {GY}{tag}{R}\n"
        )

# ── Runners ───────────────────────────────────────────────────────────
def run_oneshot(prompt: str, model: str = "", provider: str = "", verbose: bool = False):
    cmd = ["hermes", "chat", "-q", prompt]
    if model:    cmd += ["-m", model]
    if provider: cmd += ["--provider", provider]
    if verbose:  cmd.append("-v")
    subprocess.run(cmd)

def run_interactive(prompt: str, model: str = "", provider: str = "", verbose: bool = False):
    """Full interactive pty session — auto-injects prompt after hermes boots."""
    cmd = ["hermes", "chat"]
    if model:    cmd += ["-m", model]
    if provider: cmd += ["--provider", provider]
    if verbose:  cmd.append("-v")

    try:
        cols, rows = os.get_terminal_size()
    except OSError:
        cols, rows = 80, 24
    winsize = struct.pack("HHHH", rows, cols, 0, 0)

    stdin_fd = sys.stdin.fileno()
    old_tty  = termios.tcgetattr(stdin_fd)
    master_fd, slave_fd = pty.openpty()
    fcntl.ioctl(slave_fd, termios.TIOCSWINSZ, winsize)

    pid = os.fork()
    if pid == 0:
        os.close(master_fd)
        os.setsid()
        fcntl.ioctl(slave_fd, termios.TIOCSCTTY, 0)
        for fd in (0, 1, 2):
            os.dup2(slave_fd, fd)
        if slave_fd > 2:
            os.close(slave_fd)
        os.execvp(cmd[0], cmd)
        os._exit(1)

    os.close(slave_fd)

    def _resize(sig, frame):
        try:
            nc, nr = os.get_terminal_size()
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, struct.pack("HHHH", nr, nc, 0, 0))
            os.kill(pid, signal.SIGWINCH)
        except OSError:
            pass
    signal.signal(signal.SIGWINCH, _resize)

    injected  = False
    inject_at = time.monotonic() + 2.5

    try:
        tty.setraw(stdin_fd)
        while True:
            try:
                r, _, _ = select.select([master_fd, stdin_fd], [], [], 0.1)
            except (ValueError, OSError):
                break
            if master_fd in r:
                try:
                    data = os.read(master_fd, 4096)
                    if not data:
                        break
                    os.write(sys.stdout.fileno(), data)
                    sys.stdout.flush()
                except OSError:
                    break
            if not injected and time.monotonic() >= inject_at:
                try:
                    os.write(master_fd, (prompt + "\n").encode())
                except OSError:
                    break
                injected = True
            if stdin_fd in r:
                try:
                    data = os.read(stdin_fd, 4096)
                    if not data:
                        break
                    os.write(master_fd, data)
                except OSError:
                    break
    except Exception:
        pass
    finally:
        try:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_tty)
        except Exception:
            pass

    try:
        os.waitpid(pid, 0)
    except ChildProcessError:
        pass

# ── Main ──────────────────────────────────────────────────────────────
def main():
    p = argparse.ArgumentParser(
        description="Smart AI router: qwen (easy) or Claude Opus 4.8 (hard)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    p.add_argument("prompt",         nargs="*")
    p.add_argument("--force-easy",   action="store_true")
    p.add_argument("--force-hard",   action="store_true")
    p.add_argument("--dry-run",      action="store_true")
    p.add_argument("-v","--verbose",     action="store_true")
    p.add_argument("-i","--interactive", action="store_true")
    p.add_argument("-h","--help",        action="store_true")
    args = p.parse_args()

    if args.help or (not args.prompt and sys.stdin.isatty()):
        show_welcome()
        sys.exit(0)

    prompt = " ".join(args.prompt) if args.prompt else sys.stdin.read().strip()

    if not prompt:
        show_welcome()
        sys.exit(0)

    if not OR_KEY:
        sys.exit(f"{RD}ERROR:{R} OPENROUTER_API_KEY not set in environment")

    if args.force_hard:
        difficulty, tag = "hard", "(forced)"
    elif args.force_easy:
        difficulty, tag = "easy", "(forced)"
    else:
        difficulty = classify(prompt)
        tag = ""

    print_route(difficulty, tag)

    if args.dry_run:
        sys.exit(0)

    model    = HARD_MODEL if difficulty == "hard" else ""
    provider = "openrouter" if difficulty == "hard" else ""

    if args.interactive:
        run_interactive(prompt, model=model, provider=provider, verbose=args.verbose)
    else:
        run_oneshot(prompt, model=model, provider=provider, verbose=args.verbose)

if __name__ == "__main__":
    main()
