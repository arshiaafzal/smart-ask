def run_oneshot(prompt: str, model: str = "", provider: str = "", verbose: bool = False):
    cmd = ["hermes", "chat", "-q", prompt]
    if model:    cmd += ["-m", model]
    if provider: cmd += ["--provider", provider]
    if verbose:  cmd.append("-v")
    subprocess.run(cmd)

def run_interactive(prompt: str, model: str = "", provider: str = "", verbose: bool = False):
    """Full interactive pty session вҖ” auto-injects prompt after hermes boots."""
    cmd = ["hermes", "chat"]
    if model:    cmd += ["-m", model]
    if provider: cmd += ["--provider", provider]
    if verbose:  cmd.append("-v")

    try:
        cols, rows = os.get_terminal_size()
    except OSError:
        cols, rows = 80, 24
    winsize = struct.pack("HHHH", rows, cols, 0, 0)

    stdin_fd = sys.stdin.fileno()
    old_tty  = termios.tcgetattr(stdin_fd)
    master_fd, slave_fd = pty.openpty()
    fcntl.ioctl(slave_fd, termios.TIOCSWINSZ, winsize)

    pid = os.fork()
    if pid == 0:
        os.close(master_fd)
        os.setsid()
        fcntl.ioctl(slave_fd, termios.TIOCSCTTY, 0)
        for fd in (0, 1, 2):
            os.dup2(slave_fd, fd)
        if slave_fd > 2:
            os.close(slave_fd)
        os.execvp(cmd[0], cmd)
        os._exit(1)

    os.close(slave_fd)

    def _resize(sig, frame):
        try:
            nc, nr = os.get_terminal_size()
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, struct.pack("HHHH", nr, nc, 0, 0))
            os.kill(pid, signal.SIGWINCH)
        except OSError:
            pass
    signal.signal(signal.SIGWINCH, _resize)

    injected  = False
    inject_at = time.monotonic() + 2.5

    try:
        tty.setraw(stdin_fd)
        while True:
            try:
                r, _, _ = select.select([master_fd, stdin_fd], [], [], 0.1)
            except (ValueError, OSError):
                break
            if master_fd in r:
                try:
                    data = os.read(master_fd, 4096)
                    if not data:
                        break
                    os.write(sys.stdout.fileno(), data)
                    sys.stdout.flush()
                except OSError:
                    break
            if not injected and time.monotonic() >= inject_at:
                try:
                    os.write(master_fd, (prompt + "\n").encode())
                except OSError:
                    break
                injected = True
            if stdin_fd in r:
                try:
                    data = os.read(stdin_fd, 4096)
                    if not data:
                        break
                    os.write(master_fd, data)
                except OSError:
                    break
    except Exception:
        pass
    finally:
        try:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_tty)
        except Exception:
            pass

    try:
        os.waitpid(pid, 0)
    except ChildProcessError:
        pass

