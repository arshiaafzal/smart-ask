# ── ANSI palette ──────────────────────────────────────────────────────
R  = "\033[0m"
BD = "\033[1m"
DM = "\033[2m"
O  = "\033[38;5;208m"   # orange  — Claude
G  = "\033[38;5;220m"   # gold
BL = "\033[38;5;39m"    # blue    — Qwen
CY = "\033[38;5;87m"    # cyan
YL = "\033[38;5;226m"   # yellow  — money
GR = "\033[38;5;82m"    # green
PR = "\033[38;5;135m"   # purple
WH = "\033[97m"         # white
GY = "\033[38;5;245m"   # gray
RD = "\033[38;5;196m"   # red
BR = "\033[38;5;130m"   # brown   — Qwen bear body
LB = "\033[38;5;223m"   # light tan — Qwen bear snout

def _strip(s: str) -> str:
    return re.sub(r"\033\[[0-9;]*m", "", s)

def _pad(s: str, width: int) -> str:
    return s + " " * max(0, width - len(_strip(s)))

# ── Config ────────────────────────────────────────────────────────────
OR_KEY           = os.environ.get("OPENROUTER_API_KEY", "")
OR_BASE          = "https://openrouter.ai/api/v1"
CLASSIFIER_MODEL = "anthropic/claude-haiku-4.5"
HARD_MODEL       = "anthropic/claude-opus-4.8"

# ── Rain palette ──────────────────────────────────────────────────────
_GREEN_RAIN = [
    "\033[38;5;22m", "\033[38;5;28m", "\033[38;5;34m", "\033[38;5;40m",
    "\033[38;5;46m", "\033[38;5;82m", "\033[38;5;118m", "\033[38;5;154m",
]

def _rc() -> str:
    """One rain char: $ in random green shade, or space."""
    if random.random() < 0.38:
        return random.choice(_GREEN_RAIN) + "$" + R
    return " "

# ── $ rain falls into your logo, filling top → bottom ─────────────────
def _teaser():
    # Your exact logo — $ = filled, space = empty
    _LOGO = (
        "$$$$  $      $   $$$   $$$$   $$$$",
        "$       $$    $$  $   $  $    $     $",
        "$       $$  $$  $   $  $    $     $",
        "$$$   $ $$ $  $$$$  $$$$      $",
        "$       $  $  $  $   $  $  $       $",
        "$       $      $  $   $  $   $      $",
        "$$$$  $      $  $   $  $    $     $",
        "",
        "",
        "      $$$    $$$   $   $ ",
        "     $   $  $       $  $  ",
        "     $$$$   $$    $$$   ",
        "     $   $      $   $  $  ",
        "     $   $  $$$    $   $ ",
    )

    LOGO_H = len(_LOGO)
    LOGO_W = max(len(line) for line in _LOGO)

    WIDTH      = max(LOGO_W + 10, 60)
    left       = (WIDTH - LOGO_W) // 2
    RAIN_ABOVE = 2                          # rows of falling rain above the logo
    HEIGHT     = RAIN_ABOVE + LOGO_H + 1
    RAIN_H     = HEIGHT + 2

    # Build mask from logo: True wherever the logo has a '$'
    mask = [[False] * WIDTH for _ in range(HEIGHT)]
    for r, line in enumerate(_LOGO):
        for c, ch in enumerate(line):
            if ch == '$':
                mask[RAIN_ABOVE + r][left + c] = True

    # Columns that contain at least one logo cell
    letter_cols = [any(mask[r][c] for r in range(HEIGHT)) for c in range(WIDTH)]

    # Rain buffers — only for logo columns; everything else stays dark
    rain = {c: [_rc() for _ in range(RAIN_H)]
            for c in range(WIDTH) if letter_cols[c]}

    def _advance():
        for buf in rain.values():
            buf.pop()
            buf.insert(0, _rc())

    BRIGHT = "\033[38;5;46m"    # brightest green — locked cells
    LETTER = BRIGHT + "$" + R

    RAIN_FRAMES  = 25
    FILL_FRAMES  = LOGO_H       # one row locked per step, top → bottom
    TOTAL_FRAMES = RAIN_FRAMES + FILL_FRAMES
    TOTAL_LINES  = HEIGHT + 1

    animate = sys.stdout.isatty()
    if animate:
        sys.stdout.write("\033[?25l")
        sys.stdout.flush()

    try:
        for frame in range(TOTAL_FRAMES if animate else 1):
            if animate and frame > 0:
                sys.stdout.write(f"\033[{TOTAL_LINES}F")

            fill_step = frame - RAIN_FRAMES
            # Top-to-bottom fill: rows up to fill_boundary are locked bright
            fill_boundary = RAIN_ABOVE + fill_step if fill_step >= 0 else -1

            lines = []
            for row in range(HEIGHT):
                row_chars = []
                for col in range(WIDTH):
                    if mask[row][col] and row <= fill_boundary:
                        # Logo cell that has been filled — bright locked $
                        row_chars.append(LETTER)
                    elif letter_cols[col] and (fill_step < 0 or row > fill_boundary):
                        # Rain phase: fall everywhere in logo cols
                        # Fill phase: only above the current boundary (settled = dark)
                        row_chars.append(rain[col][row])
                    else:
                        row_chars.append(" ")
                lines.append("\033[2K" + "".join(row_chars))
            lines.append("\033[2K")

            sys.stdout.write("\n".join(lines) + "\n")
            sys.stdout.flush()

            _advance()
            if animate:
                time.sleep(0.09 if fill_step < 0 else 0.15)

        # Hold the final logo for a moment
        if animate:
            time.sleep(0.8)

    finally:
        if animate:
            sys.stdout.write("\033[?25h")
            sys.stdout.flush()


def _box(rows: list, inner_w: int = 52) -> None:
    """Draw a box. Rows are plain strings — no emoji, ANSI ok."""
    top = f"  {WH}{BD}╔{'═'*inner_w}╗{R}"
    bot = f"  {WH}╚{'═'*inner_w}╝{R}"
    sep = f"  {WH}╠{'═'*inner_w}╣{R}"
    print(top)
    for row in rows:
        if row is None:
            print(sep)
        else:
            visible = len(_strip(row))
            pad     = max(0, inner_w - visible)
            print(f"  {WH}║{R}{row}{' ' * pad}{WH}║{R}")
    print(bot)

