        "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘        в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ ",
        "в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘        в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— ",
        "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘        в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—",
        "в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ        в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ",
    )

    LOGO_H = len(_LOGO)
    LOGO_W = max(len(line) for line in _LOGO)

    MARGIN     = 2
    WIDTH      = LOGO_W + 2 * MARGIN
    left       = MARGIN
    RAIN_ABOVE = 2
    HEIGHT     = RAIN_ABOVE + LOGO_H + 1
    RAIN_H     = HEIGHT + 2

    # Dark palette so the bright logo pops out of the rain
    _DARK = ["\033[38;5;22m", "\033[38;5;22m", "\033[38;5;28m",
             "\033[38;5;28m", "\033[38;5;34m", "\033[38;5;40m"]
    def _rcc():
        return random.choice(_DARK) + "$" + R if random.random() < 0.28 else " "

    # logo_chars[row][col] = char to display, or None (rain shows through)
    logo_chars = [[None] * WIDTH for _ in range(HEIGHT)]
    for r, line in enumerate(_LOGO):
        for c, ch in enumerate(line):
            if ch != ' ':
                logo_chars[RAIN_ABOVE + r][left + c] = ch

    # Full-width rain вҖ” runs behind and through empty spaces in the logo
    rain = {c: [_rcc() for _ in range(RAIN_H)] for c in range(WIDTH)}

    def _advance():
        for buf in rain.values():
            buf.pop()
            buf.insert(0, _rcc())

    LOGO_C  = "\033[1;38;5;82m"    # bold vivid green вҖ” logo glyphs
    FLASH_C = "\033[1;38;5;118m"   # slightly lighter for the just-revealed row

    RAIN_FRAMES   = 22
    REVEAL_FRAMES = LOGO_H          # one row materialises per frame
    TOTAL_FRAMES  = RAIN_FRAMES + REVEAL_FRAMES
    TOTAL_LINES   = HEIGHT + 1

    animate = sys.stdout.isatty()
    if animate:
        sys.stdout.write("\033[?25l")
        sys.stdout.flush()

    try:
        for frame in range(TOTAL_FRAMES if animate else 1):
            if animate and frame > 0:
                sys.stdout.write(f"\033[{TOTAL_LINES}F")

            reveal_step = frame - RAIN_FRAMES   # <0: pure rain; вүҘ0: rows appear

            lines = []
            for row in range(HEIGHT):
                row_chars = []
                logo_row  = row - RAIN_ABOVE    # <0 above logo; 0-5 logo rows
                revealed  = reveal_step >= 0 and 0 <= logo_row <= reveal_step
                flashing  = logo_row == reveal_step   # the row that just appeared

                for col in range(WIDTH):
                    lc = logo_chars[row][col]
                    if lc is not None and revealed:
                        color = FLASH_C if flashing else LOGO_C
                        row_chars.append(color + lc + R)
                    else:
                        row_chars.append(rain[col][row])
                lines.append("\033[2K" + "".join(row_chars))
            lines.append("\033[2K")

            sys.stdout.write("\n".join(lines) + "\n")
            sys.stdout.flush()

            _advance()
            if animate:
                time.sleep(0.09 if reveal_step < 0 else 0.20)

        # Hold so the user can read the logo
        if animate:
            time.sleep(1.5)

    finally:
        if animate:
            sys.stdout.write("\033[?25h")
            sys.stdout.flush()


def _box(rows: list, inner_w: int = 52) -> None:
    """Draw a box. Rows are plain strings вҖ” no emoji, ANSI ok."""
    top = f"  {WH}{BD}в•”{'в•җ'*inner_w}в•—{R}"
    bot = f"  {WH}в•ҡ{'в•җ'*inner_w}в•қ{R}"
    sep = f"  {WH}в• {'в•җ'*inner_w}в•Ј{R}"
    print(top)
    for row in rows:
        if row is None:
            print(sep)
        else:
            visible = len(_strip(row))
            pad     = max(0, inner_w - visible)
            print(f"  {WH}в•‘{R}{row}{' ' * pad}{WH}в•‘{R}")
    print(bot)

