def main():
    p = argparse.ArgumentParser(
        description="Smart AI router: qwen (easy) or Claude Opus 4.8 (hard)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    p.add_argument("prompt",         nargs="*")
    p.add_argument("--force-easy",   action="store_true")
    p.add_argument("--force-hard",   action="store_true")
    p.add_argument("--dry-run",      action="store_true")
    p.add_argument("-v","--verbose",     action="store_true")
    p.add_argument("-i","--interactive", action="store_true")
    p.add_argument("-h","--help",        action="store_true")
    args = p.parse_args()

    if args.help or (not args.prompt and sys.stdin.isatty()):
        show_welcome()
        if args.help:
            sys.exit(0)
        # No task given вҖ” prompt for one instead of exiting
        try:
            task = input(f"  {CY}What's the task?{R}  ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if not task:
            sys.exit(0)
        args.prompt = [task]

    prompt = " ".join(args.prompt) if args.prompt else sys.stdin.read().strip()

    if not prompt:
        sys.exit(0)

    if not OR_KEY:
        sys.exit(f"{RD}ERROR:{R} OPENROUTER_API_KEY not set in environment")

    if args.force_hard:
        difficulty, tag = "hard", "(forced)"
    elif args.force_easy:
        difficulty, tag = "easy", "(forced)"
    else:
        difficulty = classify(prompt)
        tag = ""

    print_route(difficulty, tag)

    if args.dry_run:
        sys.exit(0)

    model    = HARD_MODEL if difficulty == "hard" else ""
    provider = "openrouter" if difficulty == "hard" else ""

    if args.interactive:
        run_interactive(prompt, model=model, provider=provider, verbose=args.verbose)
    else:
        run_oneshot(prompt, model=model, provider=provider, verbose=args.verbose)

if __name__ == "__main__":
    main()
