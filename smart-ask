# ── Spinner ───────────────────────────────────────────────────────────
_FRAMES = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
_COLS   = [O, G, YL, GR, CY, BL, PR, WH, O, G]
_spinner_label = ["Analyzing..."]

def _set_label(s: str) -> None:
    _spinner_label[0] = s

def _spinner(stop: threading.Event) -> None:
    i = 0
    while not stop.is_set():
        label = _spinner_label[0]
        color = _COLS[i % len(_COLS)]
        frame = _FRAMES[i % len(_FRAMES)]
        dots  = "·" * ((i // 5) % 4) + " " * (3 - (i // 5) % 4)
        bar_n = (i // 3) % 13
        bar   = f"{GR}{'█' * bar_n}{GY}{'░' * (12 - bar_n)}{R}"
        sys.stdout.write(f"\r  {color}{BD}{frame}{R}  {WH}{label}{R}{GY}{dots}{R}  {bar}  ")
        sys.stdout.flush()
        i += 1; time.sleep(0.07)
    sys.stdout.write("\r" + " " * 72 + "\r"); sys.stdout.flush()

# ── Route label ───────────────────────────────────────────────────────
def print_route(model_id: str, tag: str = "") -> None:
    if model_id == EASY_MODEL:
        print(f"\n  {BL}{BD}▸{R}  {CY}{BD}gemini-2.5-flash-lite{R}  "
              f"{GY}[easy]{R}  {GR}cheap ✓{R}  {GY}{tag}{R}")
    else:
        gate_info = f"{YL}{tag}{R}" if tag.startswith("G1") else f"{GY}{tag}{R}"
        print(f"\n  {O}{BD}▸{R}  {O}{BD}claude-opus-4.8{R}   "
              f"{YL}[hard]{R}  {O}powerful ✓{R}  {gate_info}")
    print(f"  {PR}↳  Hermes{R}\n")

# ── File context ──────────────────────────────────────────────────────
def _build_file_context(files: list[str]) -> str:
    parts = []
    for path in files:
        try:
            content = Path(path).read_text()
            parts.append(f"--- file: {path} ---\n{content}\n---\n")
        except Exception as e:
            print(f"  {RD}Warning:{R} could not read {path}: {e}", file=sys.stderr)
    return "\n".join(parts) + "\n" if parts else ""

# ── Cost (gate1 only — Hermes tracks its own) ─────────────────────────
def _print_gate_cost(tracker: TokenTracker, turn_n: int, session_cost: float) -> None:
    calls = tracker._snapshot()
    if not calls:
        return
    turn_cost = tracker.total_cost()
    W = 49
    print(f"  {GY}{'─' * W}{R}")
    for c in calls:
        print(f"  {GY}{c.model.split('/')[-1]:<24}  {c.role:<12}  {YL}${c.cost_usd:.6f}{R}")
    print(f"  {GY}{'─' * W}{R}")
    print(f"  {WH}{BD}Turn {turn_n:<4}{R}  {YL}${turn_cost:.6f}{R}"
          f"   {GY}│{R}  Session gates  {YL}${session_cost:.6f}{R}")
    print()

# ── Hermes spawn ──────────────────────────────────────────────────────
def _spawn_hermes(prompt: str, model: str) -> None:
    """Hand off to Hermes. Inherits terminal — fully interactive."""
    subprocess.run([
        "hermes", "chat", "-q", prompt,
        "-m", model, "--provider", "openrouter",
    ])

# ── Main ──────────────────────────────────────────────────────────────
def main():
    p = argparse.ArgumentParser(
        description="Smart AI router: classify → Hermes",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    p.add_argument("prompt",           nargs="*")
    p.add_argument("-f", "--file",     action="append", dest="files", metavar="FILE")
    p.add_argument("--force-easy",     action="store_true")
    p.add_argument("--force-hard",     action="store_true")
    p.add_argument("--dry-run",        action="store_true")
    p.add_argument("-h", "--help",     action="store_true")
    args = p.parse_args()

    # ── Welcome ────────────────────────────────────────────────────────
    if args.help or (not args.prompt and sys.stdin.isatty() and not args.files):
        show_welcome()
        if args.help:
            sys.exit(0)
        try:
            task = input(f"  {GR}What do you want to build today?{R}  ").strip()
        except (EOFError, KeyboardInterrupt):
            print(); sys.exit(0)
        if not task:
            sys.exit(0)
        args.prompt = [task]

    # ── Build initial prompt ───────────────────────────────────────────
    file_context = _build_file_context(args.files or [])

    if args.prompt:
        initial_prompt = " ".join(args.prompt)
    elif not sys.stdin.isatty():
        initial_prompt = sys.stdin.read().strip()
    else:
        initial_prompt = ""

    if not initial_prompt and not file_context:
        sys.exit(0)

    if not OR_KEY:
        sys.exit(f"{RD}ERROR:{R} OPENROUTER_API_KEY not set in environment")

    client          = OpenAI(base_url=OR_BASE, api_key=OR_KEY)
    session_tracker = TokenTracker()
    turn_n          = 0
    pending         = (file_context + initial_prompt).strip()

    # ── REPL loop ──────────────────────────────────────────────────────
    while True:
        if pending is not None:
            user_input = pending
            pending    = None
        else:
            try:
                print()
                user_input = input(f"  {GR}>{R} ").strip()
            except (EOFError, KeyboardInterrupt):
                print(); break
            if not user_input:
                continue

        if not user_input:
            continue
        if user_input in ("/exit", "/quit"):
            break

        turn_n      += 1
        turn_tracker = TokenTracker()

        # ── Gate 1 ─────────────────────────────────────────────────────
        if args.force_hard:
            model, tag = HARD_MODEL, "(forced)"
        elif args.force_easy:
            model, tag = EASY_MODEL, "(forced)"
        else:
            _set_label("Gate 1  classifying task")
            stop = threading.Event()
            t    = threading.Thread(target=_spinner, args=(stop,), daemon=True)
            t.start()
            try:
                difficulty, cls_usage = gate1_classify(user_input, client)
            finally:
                stop.set(); t.join()
            if cls_usage:
                turn_tracker.record(CLASSIFIER_MODEL, "classifier", cls_usage)
                session_tracker.record(CLASSIFIER_MODEL, "classifier", cls_usage)
            model = HARD_MODEL if difficulty == "hard" else EASY_MODEL
            tag   = "G1-hard"  if difficulty == "hard" else "G1-easy"

        print_route(model, tag)

        _print_gate_cost(turn_tracker, turn_n, session_tracker.total_cost())

        if args.dry_run:
            continue

        # ── Hand off to Hermes ─────────────────────────────────────────
        _spawn_hermes(user_input, model)


if __name__ == "__main__":
    main()
