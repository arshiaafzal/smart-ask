def _default_strategy_path(
    checkout_root: Path | None = None,
    install_data_root: Path | None = None,
) -> Path:
    """Locate the bundled product strategy in a checkout or installed prefix."""

    checkout_root = _REPO if checkout_root is None else Path(checkout_root)
    install_data_root = (
        Path(sysconfig.get_path("data"))
        if install_data_root is None
        else Path(install_data_root)
    )
    candidates = (
        checkout_root / "strategies" / "product.yaml",
        checkout_root.parent / "share" / "smart-ask" / "strategies" / "product.yaml",
        install_data_root / "share" / "smart-ask" / "strategies" / "product.yaml",
    )
    return next((path for path in candidates if path.is_file()), candidates[-1])

