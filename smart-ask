# ── Animated spinner ──────────────────────────────────────────────────
_FRAMES = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
_COLS   = [O, G, YL, GR, CY, BL, PR, WH, O, G]

# Shared label — written from main thread, read by spinner thread (GIL-safe for CPython)
_spinner_label = ["Analyzing..."]

def _set_label(s: str) -> None:
    _spinner_label[0] = s

def _spinner(stop: threading.Event) -> None:
    i = 0
    while not stop.is_set():
        label = _spinner_label[0]
        color = _COLS[i % len(_COLS)]
        frame = _FRAMES[i % len(_FRAMES)]
        dots  = "·" * ((i // 5) % 4) + " " * (3 - (i // 5) % 4)
        bar_n = (i // 3) % 13
        bar   = f"{GR}{'█' * bar_n}{GY}{'░' * (12 - bar_n)}{R}"
        line  = f"\r  {color}{BD}{frame}{R}  {WH}{label}{R}{GY}{dots}{R}  {bar}  "
        sys.stdout.write(line)
        sys.stdout.flush()
        i += 1
        time.sleep(0.07)
    sys.stdout.write("\r" + " " * 72 + "\r")
    sys.stdout.flush()

# ── Gate 1: classify ──────────────────────────────────────────────────

def _gate1_classify(client, prompt: str) -> str:
    """Returns 'easy' or 'hard' via Gemini classifier."""
    try:
        r = client.chat.completions.create(
            model=CLASSIFIER_MODEL,
            messages=[{"role": "user", "content": _CLASSIFY_PROMPT + prompt[:1200]}],
            max_tokens=20, temperature=0,
        )
        raw = (r.choices[0].message.content or "").strip().strip("`")
        if raw.startswith("json"):
            raw = raw[4:].strip()
        return json.loads(raw).get("d", "easy")
    except Exception:
        return "easy"


def classify(prompt: str) -> tuple:
    """
    Gate 1 only — classify the task and decide the starting model.
    Gates 2 & 3 run LIVE inside the Hermes session via _SELF_CHECK_SUFFIX.

    Returns (model_id, tag).
    """
    _set_label("Gate 1  classifying task")
    stop = threading.Event()
    t    = threading.Thread(target=_spinner, args=(stop,), daemon=True)
    t.start()
    try:
        client     = OpenAI(base_url=OR_BASE, api_key=OR_KEY)
        difficulty = _gate1_classify(client, prompt)
    finally:
        stop.set()
        t.join()

    if difficulty == "hard":
        return HARD_MODEL, "G1-hard"
    return EASY_MODEL, "G1-easy"


def _gate2_preflight(prompt: str, provider: str) -> bool:
    """
    Gate 2: run hermes non-interactively (-q) with the self-check suffix.
    Gemini generates a full answer, self-evaluates (can use terminal tool to
    run its own code), and outputs ESCALATE_NOW alone on its own line if not confident.

    Returns True if escalation was triggered.
    """
    cmd = [
        "hermes", "chat", "-q",
        prompt + _SELF_CHECK_SUFFIX,
        "-m", EASY_MODEL,
        "--provider", provider,
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
        output = result.stdout + result.stderr
        # Match only when ESCALATE_NOW appears alone on its own line — not when
        # the model merely mentions the token in prose (false positive prevention).
        return bool(re.search(r'^\s*ESCALATE_NOW\s*$', output, re.MULTILINE))
    except Exception:
        return False   # on error, don't escalate — give benefit of doubt


# ── Route label ───────────────────────────────────────────────────────
def print_route(model_id: str, tag: str = "") -> None:
    if model_id == EASY_MODEL:
        print(
            f"\n  {BL}{BD}▸{R}  {CY}{BD}gemini-2.5-flash-lite{R}  "
            f"{GY}[easy]{R}  {GR}cheap ✓{R}  {GY}{tag}{R}\n"
        )
    else:
        if tag == "G2-escalated":
            gate_info = f"{RD}↗ G2-escalated{R}  {GY}Gemini flagged insufficient — Opus takes over{R}"
        elif tag.startswith("G1"):
            gate_info = f"{YL}{tag}{R}"
        else:
            gate_info = f"{GY}{tag}{R}"
        print(
            f"\n  {O}{BD}▸{R}  {O}{BD}claude-opus-4.8{R}   "
            f"{YL}[hard]{R}  {O}powerful ✓{R}  {gate_info}\n"
        )

# ── Runners ───────────────────────────────────────────────────────────
def run_oneshot(prompt: str, model: str = "", provider: str = "", verbose: bool = False):
    cmd = ["hermes", "chat", "-q", prompt]
    if model:    cmd += ["-m", model]
    if provider: cmd += ["--provider", provider]
    if verbose:  cmd.append("-v")
    subprocess.run(cmd)

def run_interactive(prompt: str, model: str = "", provider: str = "", verbose: bool = False):
    """Full interactive PTY session — injects prompt after Hermes boots."""
    cmd = ["hermes", "chat"]
    if model:    cmd += ["-m", model]
    if provider: cmd += ["--provider", provider]
    if verbose:  cmd.append("-v")

    try:
        cols, rows = os.get_terminal_size()
    except OSError:
        cols, rows = 80, 24
    winsize = struct.pack("HHHH", rows, cols, 0, 0)

    stdin_fd = sys.stdin.fileno()
    old_tty  = termios.tcgetattr(stdin_fd)
    master_fd, slave_fd = pty.openpty()
    fcntl.ioctl(slave_fd, termios.TIOCSWINSZ, winsize)

    pid = os.fork()
    if pid == 0:
        os.close(master_fd)
        os.setsid()
        fcntl.ioctl(slave_fd, termios.TIOCSCTTY, 0)
        for fd in (0, 1, 2):
            os.dup2(slave_fd, fd)
        if slave_fd > 2:
            os.close(slave_fd)
        os.execvp(cmd[0], cmd)
        os._exit(1)

    os.close(slave_fd)

    def _resize(sig, frame):
        try:
            nc, nr = os.get_terminal_size()
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, struct.pack("HHHH", nr, nc, 0, 0))
            os.kill(pid, signal.SIGWINCH)
        except OSError:
            pass
    signal.signal(signal.SIGWINCH, _resize)

    injected  = False
    inject_at = time.monotonic() + 3.5   # wait for Hermes to fully boot

    try:
        tty.setraw(stdin_fd)
        while True:
            try:
                r, _, _ = select.select([master_fd, stdin_fd], [], [], 0.1)
            except (ValueError, OSError):
                break

            if master_fd in r:
                try:
                    data = os.read(master_fd, 4096)
                    if not data:
                        break
                    os.write(sys.stdout.fileno(), data)
                    sys.stdout.flush()
                except OSError:
                    break

            if not injected and time.monotonic() >= inject_at:
                try:
                    os.write(master_fd, (prompt + "\n").encode())
                except OSError:
                    break
                injected = True

            if stdin_fd in r:
                try:
                    data = os.read(stdin_fd, 4096)
                    if not data:
                        break
                    os.write(master_fd, data)
                except OSError:
                    break
    except Exception:
        pass
    finally:
        try:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_tty)
        except Exception:
            pass

    try:
        os.waitpid(pid, 0)
    except ChildProcessError:
        pass

# ── Main ──────────────────────────────────────────────────────────────
def main():
    p = argparse.ArgumentParser(
        description="Smart AI router: qwen (easy) or Claude Opus 4.8 (hard)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    p.add_argument("prompt",         nargs="*")
    p.add_argument("--force-easy",   action="store_true")
    p.add_argument("--force-hard",   action="store_true")
    p.add_argument("--dry-run",      action="store_true")
    p.add_argument("-v","--verbose",     action="store_true")
    p.add_argument("-i","--interactive", action="store_true")
    p.add_argument("-h","--help",        action="store_true")
    args = p.parse_args()

    if args.help or (not args.prompt and sys.stdin.isatty()):
        show_welcome()
        if args.help:
            sys.exit(0)
        # No task given — prompt for one instead of exiting
        try:
            task = input(f"  {GR}What do you want to build today?{R}  ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if not task:
            sys.exit(0)
        args.prompt = [task]

    prompt = " ".join(args.prompt) if args.prompt else sys.stdin.read().strip()

    if not prompt:
        sys.exit(0)

    if not OR_KEY:
        sys.exit(f"{RD}ERROR:{R} OPENROUTER_API_KEY not set in environment")

    provider = "openrouter"

    if args.force_hard:
        model, tag = HARD_MODEL, "(forced)"
    elif args.force_easy:
        model, tag = EASY_MODEL, "(forced)"
    else:
        # ── Gate 1: classify ──────────────────────────────────────────
        model, tag = classify(prompt)

        # ── Gate 2: preflight quality check (easy tasks only) ─────────
        if model == EASY_MODEL:
            _set_label("Gate 2  Gemini preflight check")
            stop = threading.Event()
            t    = threading.Thread(target=_spinner, args=(stop,), daemon=True)
            t.start()
            try:
                escalated = _gate2_preflight(prompt, provider)
            finally:
                stop.set()
                t.join()
            if escalated:
                model, tag = HARD_MODEL, "G2-escalated"

    print_route(model, tag)

    if args.dry_run:
        sys.exit(0)

    # For G2-escalated: give Opus context about why it's being used
    if tag == "G2-escalated":
        effective_prompt = (
            f"A previous quick attempt at this task by a cheaper model was flagged as "
            f"insufficient (stub code, failed examples, or high-level outline only).\n\n"
            f"Please solve this completely and correctly:\n\n{prompt}"
        )
    else:
        effective_prompt = prompt

    run_interactive(effective_prompt, model=model, provider=provider, verbose=args.verbose)

if __name__ == "__main__":
    main()
