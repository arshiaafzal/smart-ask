# Copy this file to claude-smart-ask.local.env. The default Sonnet/Opus strategy
# needs only ANTHROPIC_API_KEY. The local file is ignored by Git.

ANTHROPIC_API_KEY="sk-ant-..."

# Optional: use an Anthropic-compatible Foundry deployment instead.
# ANTHROPIC_FOUNDRY_BASE_URL="https://..."
# ANTHROPIC_FOUNDRY_API_KEY="..."
# ANTHROPIC_DEFAULT_SONNET_MODEL="claude-sonnet-4-6"
# ANTHROPIC_DEFAULT_OPUS_MODEL="claude-opus-4-6"

# Only needed by optional non-default strategies.
OPENAI_API_KEY="sk-..."
OPENROUTER_API_KEY="sk-or-..."
GROQ_API_KEY="gsk_..."
