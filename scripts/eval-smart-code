#!/usr/bin/env bash

# Run one real Claude Code prompt through SmartAsk and print its routing/cost
# summary. Process setup, authentication, and model selection stay in the main
# launcher so this evaluator cannot drift from the product path.

set -euo pipefail

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
STRATEGY=${SMART_ASK_DEFAULT_STRATEGY:-agentic-coding-v1}

usage() {
    cat <<'EOF'
Usage:
  scripts/eval-smart-code [--strategy NAME] "prompt"

The normal Sonnet/Opus strategy is used by default. Set
SMART_ASK_METRICS_PATH to keep appending to a specific metrics file.
EOF
}

case "${1:-}" in
    help|-h|--help)
        usage
        exit 0
        ;;
esac

if [ "${1:-}" = "--strategy" ]; then
    [ -n "${2:-}" ] || { echo "error: --strategy requires a name" >&2; exit 1; }
    STRATEGY=$2
    shift 2
fi
[ "$#" -gt 0 ] || { usage >&2; exit 1; }

if [ -z "${SMART_ASK_METRICS_PATH:-}" ]; then
    SMART_ASK_METRICS_PATH=$(mktemp "${TMPDIR:-/tmp}/smart-ask-eval.XXXXXX.jsonl")
fi
export SMART_ASK_METRICS_PATH

"$ROOT_DIR/scripts/claude-smart-ask" \
    --strategy "$STRATEGY" \
    -p "$*" --print

if [ -x "$ROOT_DIR/.venv/bin/python" ]; then
    PYTHON=$ROOT_DIR/.venv/bin/python
else
    PYTHON=python3
fi
"$PYTHON" "$ROOT_DIR/benchmark/analyze.py" "$SMART_ASK_METRICS_PATH"
